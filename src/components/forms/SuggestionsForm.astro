<section class="relative bg-gradient-to-br from-primary-50 via-white to-gold-50/20 py-20 lg:py-24 px-4 sm:px-6 overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary-300/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-gold-500/5 rounded-full blur-3xl"></div>

  <div class="max-w-2xl mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary-100 text-primary-700 text-sm font-semibold mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
        </svg>
        Tu opinión es importante
      </span>
      <h2 class="text-3xl lg:text-5xl font-bold text-gray-900 mb-4 font-serif">
        Buzón de Sugerencias
      </h2>
      <p class="text-lg text-gray-600 max-w-xl mx-auto font-body">
        Queremos escucharte. Comparte tu queja, sugerencia o felicitación para seguir mejorando nuestro servicio.
      </p>
    </div>

    <!-- Form Card -->
    <div class="bg-white p-8 lg:p-10 rounded-3xl shadow-soft-lg border border-gray-100 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-gold-50/30 via-white to-primary-50/20 pointer-events-none"></div>
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary-300 via-gold-500 to-primary-500"></div>

      <form id="suggestions-form" class="relative space-y-5">
        <!-- Nombre -->
        <div class="relative">
          <label for="sug-nombre" class="absolute -top-2.5 left-4 px-2 bg-white text-xs font-medium text-gray-600 z-10">
            Nombre completo <span class="text-gold-500">*</span>
          </label>
          <input type="text" id="sug-nombre" name="nombre" placeholder="Tu nombre" required autocomplete="name"
            class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-gray-800 placeholder-gray-400 transition-all duration-300 hover:border-primary-300 focus:outline-none focus:border-primary-400 focus:ring-4 focus:ring-primary-100" />
        </div>

        <!-- Teléfono -->
        <div class="relative">
          <label for="sug-telefono" class="absolute -top-2.5 left-4 px-2 bg-white text-xs font-medium text-gray-600 z-10">
            Celular <span class="text-gold-500">*</span>
          </label>
          <div class="flex">
            <select id="sug-indicativo" name="indicativo"
              class="appearance-none px-3 py-4 bg-gray-50 border-2 border-r-0 border-gray-200 rounded-l-2xl text-gray-600 text-sm font-medium cursor-pointer hover:bg-gray-100 focus:outline-none focus:bg-white focus:border-primary-400 transition-all duration-300"
              style="min-width: 90px;">
              <option value="+57">🇨🇴 +57</option>
              <option value="+1">🇺🇸 +1</option>
              <option value="+52">🇲🇽 +52</option>
              <option value="+34">🇪🇸 +34</option>
              <option value="+51">🇵🇪 +51</option>
              <option value="+56">🇨🇱 +56</option>
              <option value="+54">🇦🇷 +54</option>
              <option value="+593">🇪🇨 +593</option>
              <option value="+58">🇻🇪 +58</option>
              <option value="+507">🇵🇦 +507</option>
            </select>
            <input type="tel" id="sug-telefono" name="telefono" placeholder="300 123 4567" required autocomplete="tel"
              class="w-full px-4 py-4 bg-white border-2 border-l-0 border-gray-200 rounded-r-2xl text-gray-800 placeholder-gray-400 transition-all duration-300 hover:border-primary-300 focus:outline-none focus:border-primary-400 focus:ring-4 focus:ring-primary-100" />
          </div>
        </div>

        <!-- Email -->
        <div class="relative">
          <label for="sug-email" class="absolute -top-2.5 left-4 px-2 bg-white text-xs font-medium text-gray-600 z-10">
            Correo electrónico <span class="text-gray-400 font-normal">(Opcional)</span>
          </label>
          <input type="email" id="sug-email" name="email" placeholder="correo@ejemplo.com" autocomplete="email"
            class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-gray-800 placeholder-gray-400 transition-all duration-300 hover:border-primary-300 focus:outline-none focus:border-primary-400 focus:ring-4 focus:ring-primary-100" />
        </div>

        <!-- Tipo -->
        <div class="relative">
          <label for="sug-tipo" class="absolute -top-2.5 left-4 px-2 bg-white text-xs font-medium text-gray-600 z-10">
            Tipo de mensaje <span class="text-gold-500">*</span>
          </label>
          <select id="sug-tipo" name="tipo" required
            class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-gray-800 appearance-none cursor-pointer transition-all duration-300 hover:border-primary-300 focus:outline-none focus:border-primary-400 focus:ring-4 focus:ring-primary-100 bg-no-repeat"
            style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 fill=%27none%27 viewBox=%270 0 24 24%27 stroke=%27%236b7280%27 stroke-width=%272%27%3E%3Cpath stroke-linecap=%27round%27 stroke-linejoin=%27round%27 d=%27M19 9l-7 7-7-7%27/%3E%3C/svg%3E'); background-size: 1.25rem; background-position: right 1rem center;">
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="Queja">Queja</option>
            <option value="Sugerencia">Sugerencia</option>
            <option value="Felicitación">Felicitación</option>
          </select>
        </div>

        <!-- Mensaje -->
        <div class="relative">
          <label for="sug-mensaje" class="absolute -top-2.5 left-4 px-2 bg-white text-xs font-medium text-gray-600 z-10">
            Mensaje <span class="text-gold-500">*</span>
          </label>
          <textarea id="sug-mensaje" name="mensaje" placeholder="Escribe tu mensaje aquí..." required rows="5"
            class="w-full px-5 py-4 bg-white border-2 border-gray-200 rounded-2xl text-gray-800 placeholder-gray-400 resize-y transition-all duration-300 hover:border-primary-300 focus:outline-none focus:border-primary-400 focus:ring-4 focus:ring-primary-100"></textarea>
        </div>

        <!-- Checkbox de términos -->
        <div class="relative">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input type="checkbox" name="acepta_terminos" required
              class="mt-1 w-5 h-5 rounded border-2 border-gray-300 text-primary-400 focus:ring-2 focus:ring-primary-300/20 focus:ring-offset-0 checked:bg-primary-400 checked:border-primary-400 transition-all duration-200 cursor-pointer accent-primary-400" />
            <span class="text-sm text-gray-600 leading-relaxed font-body">
              Acepto la <a href="/contacto" target="_blank" class="text-primary-600 hover:text-primary-700 underline font-medium">política de tratamiento de datos</a> y autorizo el contacto para fines relacionados con mi solicitud.
            </span>
          </label>
        </div>

        <!-- Submit Button -->
        <div class="pt-3">
          <button type="submit" id="suggestions-submit-btn"
            class="w-full px-8 py-4 bg-gradient-to-r from-primary-300 to-primary-400 text-white font-bold text-lg rounded-2xl shadow-lg hover:shadow-xl hover:from-primary-400 hover:to-primary-500 transform hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 flex items-center justify-center gap-3 group">
            <svg class="w-5 h-5" data-button-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
            <span data-button-text>Enviar Mensaje</span>
            <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
            <svg class="w-5 h-5 animate-spin hidden" data-loading-spinner fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
            </svg>
          </button>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 pt-4 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Revisamos cada mensaje</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>100% confidencial</span>
          </div>
        </div>
      </form>

      <div id="suggestions-status" class="hidden mt-5 p-4 rounded-xl text-sm font-medium" role="alert"></div>
    </div>
  </div>
</section>

<script>
  function initSuggestionsForm() {
    const form = document.getElementById('suggestions-form') as HTMLFormElement;
    const status = document.getElementById('suggestions-status');
    const submitBtn = document.getElementById('suggestions-submit-btn');
    const buttonText = submitBtn?.querySelector('[data-button-text]');
    const buttonIcon = submitBtn?.querySelector('[data-button-icon]');
    const spinner = submitBtn?.querySelector('[data-loading-spinner]');

    if (!form || !status || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      submitBtn.setAttribute('disabled', 'true');
      buttonText?.classList.add('hidden');
      buttonIcon?.classList.add('hidden');
      spinner?.classList.remove('hidden');

      try {
        let phoneDigits = String(data.telefono).replace(/\D/g, '');
        const countryCode = String(data.indicativo).replace(/\D/g, '');
        if (phoneDigits.startsWith(countryCode)) {
          phoneDigits = phoneDigits.slice(countryCode.length);
        }
        const cleanPhone = `${data.indicativo}${phoneDigits}`;

        const response = await fetch('/api/suggestions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: data.nombre,
            phone: cleanPhone,
            email: data.email,
            tipo: data.tipo,
            message: data.mensaje,
          })
        });

        if (response.ok) {
          status.innerHTML = `<div class="flex items-center gap-3"><svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span>¡Gracias por tu mensaje! Lo revisaremos con atención.</span></div>`;
          status.className = 'mt-5 p-5 rounded-xl text-base font-semibold bg-green-100 text-green-900 border-2 border-green-400 shadow-lg';
          form.reset();
        } else {
          throw new Error('Error en el servidor');
        }
      } catch (error) {
        status.innerHTML = `<div class="flex items-center gap-3"><svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span>Hubo un error al enviar. Por favor intenta de nuevo.</span></div>`;
        status.className = 'mt-5 p-5 rounded-xl text-base font-semibold bg-red-100 text-red-900 border-2 border-red-400 shadow-lg';
      } finally {
        submitBtn.removeAttribute('disabled');
        buttonText?.classList.remove('hidden');
        buttonIcon?.classList.remove('hidden');
        spinner?.classList.add('hidden');
        status.classList.remove('hidden');
        setTimeout(() => { status.classList.add('hidden'); }, 8000);
      }
    });
  }

  initSuggestionsForm();
  document.addEventListener('astro:page-load', initSuggestionsForm);
</script>
